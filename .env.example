# Debrief core requires no environment variables — the CSV-upload flow
# runs from `npm run dev` / `npm run build` with nothing to configure.
#
# The OPTIONAL Meta data source ("Connect Meta account" in the
# generator) needs a Meta app with the ads_read permission. Without
# these three vars the connect button returns a clear "not configured"
# error and the CSV-upload flow is unaffected.
#
# Register the exact redirect URI below (per environment) under
# Facebook Login → Settings → Valid OAuth Redirect URIs in the Meta
# app dashboard.

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/meta/callback
