# Debrief core requires no environment variables — the CSV-upload flow
# runs from `npm run dev` / `npm run build` with nothing to configure.
#
# The OPTIONAL Meta data source ("Connect Meta account" in the
# generator) needs a Meta app with the ads_read permission. Without
# META_APP_ID + META_APP_SECRET the connect button is disabled with a
# clear "not configured" message and the CSV-upload flow is unaffected.

META_APP_ID=
META_APP_SECRET=

# Redirect URI — usually LEAVE UNSET. The app derives it from the
# request origin per environment:
#   local dev    -> http://localhost:3000/api/meta/callback
#   production   -> https://<your-domain>/api/meta/callback
# Set it only to override that derivation (e.g. behind a proxy whose
# public origin differs from the request host). If set, it must be an
# absolute URL ending in /api/meta/callback; plain http is only valid
# for localhost.
#
# Whichever URIs your environments end up using must be registered
# VERBATIM under Facebook Login → Settings → Valid OAuth Redirect URIs
# in the Meta app dashboard. GET /api/meta/config on any deployment
# shows the exact URI it will send (no secrets).
#META_REDIRECT_URI=

# ------------------------------------------------------------------
# OPTIONAL: Competitor Monitoring Beta (flag defaults OFF).
# With everything below unset, the product is exactly the pre-beta
# app: no monitoring routes, no cron work, no UI section, no database
# connection is ever attempted.
#
# Setup steps (Neon via Vercel Marketplace): docs/monitoring-setup.md

# Master switch. Only the exact values "true" or "1" enable the beta.
#MONITORING_ENABLED=

# Neon Postgres connection string for the monitoring schema ONLY.
# Use a FRESH Neon project/database — the guarded migration
# (`npm run monitoring:migrate`) refuses to run against a database
# containing unexpected tables. Never point this at a pre-existing db.
#DATABASE_URL=

# Shared secret for POST /api/monitoring/cron (compared in constant
# time). Also the derivation input for the rate-limit key salt
# (SHA-256("debrief-ip-salt:" + CRON_SECRET)) — rotating it resets
# in-flight rate-limit windows, which is harmless. Required whenever
# MONITORING_ENABLED is on. Generate with: openssl rand -base64 32
#CRON_SECRET=

# Global ceiling on active monitored URLs across ALL workspaces.
# Optional; defaults to 500 when unset.
#MONITORING_MAX_ACTIVE_URLS=

# ------------------------------------------------------------------
# OPTIONAL: "Search advertiser — EU/UK beta" mode on /competitor-debrief
# (Meta Ad Library API Integration V1: modules/metaAdLibrary/,
# app/api/meta-ad-library/*). A Meta User Access Token with the
# ads_read permission, generated via Graph API Explorer after
# completing Meta's identity verification. Server-side ONLY — never
# NEXT_PUBLIC_, never sent to the browser, never logged. With this
# unset, the mode fails safely with a clear "isn't configured" message
# and both paste modes are unaffected. Also used by the manual probe
# script (scripts/metaAdLibraryProbe.ts).
#
# NOTE: this is the ONE standardized key name. If your .env.local
# still holds the token under the old pre-pivot key META_ACCESS_TOKEN,
# rename that key to META_AD_LIBRARY_ACCESS_TOKEN yourself (the value
# stays the same; nothing migrates it automatically).
#META_AD_LIBRARY_ACCESS_TOKEN=
